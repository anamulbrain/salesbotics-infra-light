aws_region   = "ap-south-1"
project_name = "salesbotics"
environment  = "dev"

# Optional: set after requesting ACM cert in ap-south-1
# acm_certificate_arn = "arn:aws:acm:ap-south-1:444083008308:certificate/..."

# Optional: override auto-generated auth server admin password
# auth_admin_password = "your-secure-password"

# RDS public access (dev) — set your public IP from: curl -4 ifconfig.me
# rds_publicly_accessible = true
# rds_admin_cidr_blocks   = ["203.0.113.1/32"]

# Copy to terraform.tfvars (gitignored) to override defaults.
